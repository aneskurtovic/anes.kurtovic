---
interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  publishedDate?: string;
  tags?: string[];
}

const {
  title = 'Anes Kurtovic | Software Engineer',
  description = 'Portfolio of Anes Kurtovic — Software Engineer specializing in .NET, microservices, and full-stack development.',
  ogType = 'website',
  publishedDate,
  tags,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const personId = `${Astro.site}#person`;
const websiteId = `${Astro.site}#website`;

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': personId,
      name: 'Anes Kurtovic',
      url: Astro.site?.toString(),
      jobTitle: 'Software Engineer',
      description:
        'Software Engineer specializing in .NET microservices and full-stack development.',
      sameAs: [
        'https://github.com/aneskurtovic',
        'https://linkedin.com/in/anes-kurtovic-b50040135',
      ],
      email: 'mailto:anes.kurtovic@gmail.com',
      knowsAbout: [
        '.NET',
        'C#',
        'Microservices',
        'Software Architecture',
        'Domain-Driven Design',
        'Event Sourcing',
        'React',
        'TypeScript',
      ],
      worksFor: {
        '@type': 'Organization',
        name: 'Roko Labs',
      },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Sarajevo',
        addressCountry: 'BA',
      },
    },
    {
      '@type': 'WebSite',
      '@id': websiteId,
      url: Astro.site?.toString(),
      name: 'Anes Kurtovic — Software Engineer',
      description:
        'Portfolio of Anes Kurtovic — Software Engineer specializing in .NET, microservices, and full-stack development.',
      publisher: { '@id': personId },
      inLanguage: 'en',
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Anes Kurtovic" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="Anes Kurtovic" />
    <meta property="og:locale" content="en_US" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {tags && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // Mobile nav toggle
        const toggle = document.getElementById('nav-toggle');
        const links = document.getElementById('nav-links');
        const close = document.getElementById('nav-close');
        const backdrop = document.getElementById('nav-backdrop');
        const openMenu = () => {
          links?.classList.add('open');
          backdrop?.classList.add('open');
          document.body.style.overflow = 'hidden';
        };
        const closeMenu = () => {
          links?.classList.remove('open');
          backdrop?.classList.remove('open');
          document.body.style.overflow = '';
        };
        toggle?.addEventListener('click', () => {
          if (links?.classList.contains('open')) closeMenu();
          else openMenu();
        });
        close?.addEventListener('click', closeMenu);
        backdrop?.addEventListener('click', closeMenu);
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && links?.classList.contains('open')) closeMenu();
        });
        links?.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', closeMenu)
        );

        // Navbar glassmorphism on scroll
        const nav = document.getElementById('nav');
        window.addEventListener('scroll', () => {
          nav?.classList.toggle('scrolled', window.scrollY > 50);
        });

        // Active nav link based on scroll position
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.nav-link');
        window.addEventListener('scroll', () => {
          let current = '';
          sections.forEach((section) => {
            const top = section.offsetTop - 120;
            if (window.scrollY >= top) {
              current = section.getAttribute('id') || '';
            }
          });
          navLinks.forEach((link) => {
            link.classList.remove('active');
            if (link.getAttribute('href') === '#' + current) {
              link.classList.add('active');
            }
          });
        });

        // Intersection Observer for scroll reveal
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => observer.observe(el));

        // Mouse-following glow (desktop only)
        const glow = document.getElementById('mouse-glow');
        const hero = document.getElementById('hero');
        if (glow && hero && window.innerWidth > 768) {
          hero.addEventListener('mousemove', (e) => {
            const rect = hero.getBoundingClientRect();
            glow.style.left = (e.clientX - rect.left) + 'px';
            glow.style.top = (e.clientY - rect.top) + 'px';
            glow.style.opacity = '1';
          });
          hero.addEventListener('mouseleave', () => {
            glow.style.opacity = '0';
          });
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/animations.css';
</style>
