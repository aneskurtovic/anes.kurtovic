---
import { agents } from '../data/agents';
const start = agents[0];
---

<div id="terminal-overlay" class="term-overlay" role="dialog" aria-modal="true" aria-label="Terminal — talk to the (useless) AI" hidden>
  <div id="terminal-panel" class="term-panel" style={`--agent-accent:${start.accent}`}>
    <!-- Red flash layer for Goggins gag -->
    <div id="term-flash" class="term-flash" aria-hidden="true"></div>

    <!-- Header -->
    <div class="term-header">
      <img id="term-avatar" class="term-avatar" src={start.avatarNeutral} alt="" width="56" height="56" />
      <div class="term-id">
        <span id="term-name" class="term-name">{start.name}</span>
        <span id="term-role" class="term-role">{start.role}</span>
      </div>
      <button id="term-close" class="term-close" aria-label="Close terminal">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none">
          <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <!-- Action buttons -->
    <div class="term-actions">
      <button id="term-swap" class="term-btn">⇄ swap agent</button>
      <button id="term-quit" class="term-btn">✕ quit chat</button>
      <button id="term-anes" class="term-btn">☎ talk to Anes</button>
    </div>

    <!-- Log -->
    <div id="term-log" class="term-log" aria-live="polite"></div>

    <!-- Input -->
    <form id="term-form" class="term-input-row">
      <span class="term-prompt">$</span>
      <input id="term-input" class="term-input" type="text" autocomplete="off" aria-label="Type a message" placeholder="type something and hit enter…" />
      <button type="submit" class="term-send" aria-label="Send">↵</button>
    </form>

    <!-- Footer -->
    <p class="term-note" id="term-note"></p>
  </div>
</div>

<style>
  .term-overlay {
    position: fixed;
    inset: 0;
    z-index: 3000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgba(5, 5, 9, 0.85);
    backdrop-filter: blur(6px);
  }

  .term-overlay[hidden] {
    display: none;
  }

  .term-panel {
    width: min(680px, 100%);
    height: min(78vh, 640px);
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6);
    overflow: hidden;
    position: relative;
    font-family: var(--font-mono);
  }

  .term-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    background: rgba(30, 30, 46, 0.4);
  }

  .term-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--agent-accent, var(--accent));
    background: var(--bg);
    transition: border-color 0.3s;
    animation: term-float 3.5s ease-in-out infinite;
  }

  .term-avatar.speaking {
    animation: term-bob 0.5s ease-in-out infinite;
  }

  .term-avatar.swapping {
    animation: term-swap 0.35s ease;
  }

  .term-avatar.goggins-in {
    animation: term-slam 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .term-id {
    flex: 1;
  }

  .term-name {
    display: block;
    color: var(--agent-accent, var(--accent));
    font-weight: 600;
    text-transform: lowercase;
  }

  .term-role {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .term-close {
    margin-left: auto;
    color: var(--text-muted);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: var(--radius);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
  }

  .term-close:hover {
    color: var(--text);
    background: var(--bg-card-hover);
  }

  .term-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .term-btn {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.35rem 0.6rem;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
  }

  .term-btn:hover {
    color: var(--agent-accent, var(--accent));
    border-color: var(--agent-accent, var(--accent));
    background: var(--bg-card-hover);
  }

  .term-log {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .line-agent {
    color: var(--text);
  }

  .line-user {
    color: var(--text-muted);
  }

  .line-user::before {
    content: 'you> ';
    color: var(--text-muted);
  }

  .line-goggins {
    color: #ef4444;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .line-system {
    color: var(--text-muted);
    font-style: italic;
    font-size: 0.75rem;
  }

  .term-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }

  .term-prompt {
    color: var(--agent-accent, var(--accent));
    font-weight: 700;
  }

  .term-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    caret-color: var(--agent-accent, var(--accent));
  }

  .term-send {
    color: var(--agent-accent, var(--accent));
    font-size: 1rem;
    padding: 0 0.4rem;
    border: none;
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
  }

  .term-send:hover {
    transform: scale(1.1);
  }

  .term-note {
    padding: 0.4rem 1rem 0.6rem;
    margin: 0;
    font-size: 0.62rem;
    color: var(--text-muted);
    opacity: 0.6;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .term-flash {
    position: absolute;
    inset: 0;
    background: #ef4444;
    opacity: 0;
    pointer-events: none;
    z-index: 5;
  }

  .term-flash.hit {
    animation: term-flash-anim 0.5s ease-out;
  }

  @keyframes term-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  @keyframes term-bob {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
    }
    50% {
      transform: scale(1.05) rotate(2deg);
    }
  }

  @keyframes term-slam {
    0% {
      transform: scale(1.5) translateX(-8px);
    }
    50% {
      transform: scale(1.1) translateX(4px);
    }
    100% {
      transform: scale(1) translateX(0);
    }
  }

  @keyframes term-swap {
    0% {
      opacity: 1;
      transform: translateX(0);
    }
    50% {
      opacity: 0.5;
      transform: translateX(-8px);
    }
    100% {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes term-flash-anim {
    0% {
      opacity: 0;
    }
    30% {
      opacity: 0.5;
    }
    100% {
      opacity: 0;
    }
  }

  @media (max-width: 480px) {
    .term-panel {
      height: 88vh;
    }

    .term-avatar {
      width: 48px;
      height: 48px;
    }

    .term-actions {
      flex-wrap: wrap;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .term-avatar,
    .term-avatar.speaking,
    .term-avatar.goggins-in,
    .term-avatar.swapping,
    .term-flash.hit {
      animation: none !important;
    }
  }
</style>

<script>
  import { agents, goggins, parodyNote, bootLines } from '../data/agents';

  const WORKER_URL = 'https://REPLACE-ME.workers.dev';
  // TODO: replace with deployed Worker URL (see worker/README.md).
  // Until then, asks gracefully fall back to canned lines.

  // DOM elements
  const overlay = document.getElementById('terminal-overlay');
  const panel = document.getElementById('terminal-panel');
  const avatar = document.getElementById('term-avatar') as HTMLImageElement;
  const name = document.getElementById('term-name');
  const role = document.getElementById('term-role');
  const log = document.getElementById('term-log');
  const input = document.getElementById('term-input') as HTMLInputElement;
  const form = document.getElementById('term-form');
  const closeBtn = document.getElementById('term-close');
  const swapBtn = document.getElementById('term-swap');
  const quitBtn = document.getElementById('term-quit');
  const anesBtn = document.getElementById('term-anes');
  const note = document.getElementById('term-note');
  const flash = document.getElementById('term-flash');

  // Guard: early exit if elements missing
  if (!overlay || !avatar || !name || !role || !log || !input || !form || !note) {
    console.warn('Terminal: missing required DOM elements');
  }

  // Set parody note
  if (note) note.textContent = parodyNote;

  // State
  let activeIndex = 0;
  let opened = false;
  let busy = false;
  let history: Array<{ role: string; content: string }> = [];
  let lastFocus: HTMLElement | null = null;

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const current = () => agents[activeIndex];

  const rand = (arr: string[]): string => arr[Math.floor(Math.random() * arr.length)];

  function setAccent(hex: string) {
    if (panel) panel.style.setProperty('--agent-accent', hex);
  }

  function applyAgent(agent: any) {
    if (avatar) {
      avatar.src = agent.avatarNeutral;
      avatar.alt = agent.name;
    }
    if (name) name.textContent = agent.name;
    if (role) role.textContent = agent.role;
    setAccent(agent.accent);
  }

  function scrollLog() {
    if (log) log.scrollTop = log.scrollHeight;
  }

  function addLine(text: string, cls: string): HTMLElement {
    const el = document.createElement('div');
    el.className = `line ${cls}`;
    el.textContent = text;
    if (log) log.appendChild(el);
    scrollLog();
    return el;
  }

  async function typeLine(
    text: string,
    cls: string,
    avatarSrcNeutral: string,
    avatarSrcTalking: string
  ): Promise<void> {
    if (reduce) {
      // Skip animation, just set instantly
      addLine(text, cls);
      return;
    }

    const el = document.createElement('div');
    el.className = `line ${cls}`;
    if (log) log.appendChild(el);

    if (avatar) avatar.classList.add('speaking');

    let charIndex = 0;
    const charDelay = 16; // ~60 FPS
    let isTalkingFrame = false;

    return new Promise<void>((resolve) => {
      const typeInterval = setInterval(() => {
        if (charIndex < text.length) {
          el.textContent = text.substring(0, charIndex + 1);
          charIndex++;

          // Toggle mouth flap every ~180ms (~12 chars at 16ms/char)
          if (charIndex % 12 === 0) {
            isTalkingFrame = !isTalkingFrame;
            if (avatar) {
              avatar.src = isTalkingFrame ? avatarSrcTalking : avatarSrcNeutral;
            }
          }

          scrollLog();
        } else {
          clearInterval(typeInterval);

          // Restore to neutral, remove speaking class
          if (avatar) {
            avatar.src = avatarSrcNeutral;
            avatar.classList.remove('speaking');
          }

          resolve();
        }
      }, charDelay);
    });
  }

  function openTerminal() {
    if (opened) return;
    lastFocus = document.activeElement as HTMLElement;
    if (overlay) overlay.hidden = false;
    opened = true;
    document.body.style.overflow = 'hidden';
    applyAgent(current());

    // If log is empty, run the fake boot sequence then the greeting
    if (log && log.childElementCount === 0) {
      for (const b of bootLines) addLine(b, 'line-system');
      busy = true;
      typeLine(rand(current().greetings), 'line-agent', current().avatarNeutral, current().avatarTalking)
        .finally(() => { busy = false; });
    }

    if (input) input.focus();
  }

  function closeTerminal() {
    if (!opened) return;
    if (overlay) overlay.hidden = true;
    opened = false;
    document.body.style.overflow = '';
    lastFocus?.focus();
  }

  async function doSwap() {
    if (busy) return;
    busy = true;
    try {
      await typeLine(rand(current().swapOut), 'line-agent', current().avatarNeutral, current().avatarTalking);

      if (avatar) {
        avatar.classList.add('swapping');
        await new Promise((r) => setTimeout(r, 400));
        avatar.classList.remove('swapping');
      }

      activeIndex = (activeIndex + 1) % agents.length;
      history = [];
      applyAgent(current());

      await typeLine(rand(current().swapIn), 'line-agent', current().avatarNeutral, current().avatarTalking);
    } finally {
      busy = false;
      if (input) input.focus();
    }
  }

  async function doAnes() {
    if (busy) return;
    busy = true;
    try {
      await typeLine(rand(current().anesMock), 'line-agent', current().avatarNeutral, current().avatarTalking);
    } finally {
      busy = false;
      if (input) input.focus();
    }
  }

  async function doQuit() {
    if (busy) return;
    busy = true;
    try {
      const prev = current();
      applyAgent(goggins as any);

      if (avatar) {
        avatar.classList.add('goggins-in');
      }
      if (flash) {
        flash.classList.add('hit');
      }

      await new Promise((r) => setTimeout(r, 600));

      if (avatar) {
        avatar.classList.remove('goggins-in');
      }
      if (flash) {
        flash.classList.remove('hit');
      }

      await typeLine(rand(goggins.quitLines), 'line-goggins', goggins.avatarNeutral, goggins.avatarTalking);

      await new Promise((r) => setTimeout(r, reduce ? 200 : 900));

      applyAgent(prev);
      await typeLine(rand(prev.resume), 'line-agent', prev.avatarNeutral, prev.avatarTalking);
    } finally {
      busy = false;
      if (input) input.focus();
    }
  }

  async function doSubmit(e: Event) {
    e.preventDefault();
    if (busy) return;

    const text = input?.value.trim() || '';
    if (!text) return;

    addLine(text, 'line-user');
    if (input) input.value = '';
    history.push({ role: 'user', content: text });

    const typing = addLine('…', 'line-system');
    busy = true;
    if (avatar) avatar.classList.add('speaking');

    try {
      const res = await fetch(WORKER_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          agent: current().id,
          messages: history.slice(-6),
        }),
      });

      typing.remove();
      if (avatar) avatar.classList.remove('speaking');

      if (!res.ok) throw new Error('Worker returned non-2xx');

      const data = await res.json();
      const reply = data?.reply ? String(data.reply) : '';

      if (!reply) throw new Error('No reply from worker');

      history.push({ role: 'assistant', content: reply });
      await typeLine(reply, 'line-agent', current().avatarNeutral, current().avatarTalking);
    } catch (err) {
      typing.remove();
      if (avatar) avatar.classList.remove('speaking');
      await typeLine(rand(current().askFallback), 'line-agent', current().avatarNeutral, current().avatarTalking);
    } finally {
      busy = false;
      if (input) input.focus();
    }
  }

  // Event listeners
  if (form) form.addEventListener('submit', doSubmit);
  if (closeBtn) closeBtn.addEventListener('click', closeTerminal);
  if (swapBtn) swapBtn.addEventListener('click', doSwap);
  if (quitBtn) quitBtn.addEventListener('click', doQuit);
  if (anesBtn) anesBtn.addEventListener('click', doAnes);

  // Global open triggers
  document.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement)?.closest?.('[data-terminal-open]');
    if (target) {
      e.preventDefault();
      openTerminal();
    }
  });

  document.addEventListener('keydown', (e) => {
    const tag = (e.target as HTMLElement)?.tagName;
    const typing = tag === 'INPUT' || tag === 'TEXTAREA' || (e.target as HTMLElement)?.isContentEditable;

    if (e.key === '`' && !opened && !typing) {
      e.preventDefault();
      openTerminal();
    }

    if (e.key === 'Escape' && opened) {
      closeTerminal();
    }

    // Basic focus trap on Tab
    if (e.key === 'Tab' && opened && panel) {
      const focusable = panel.querySelectorAll<HTMLElement>('button, input, [href], [tabindex]');
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      const active = document.activeElement as HTMLElement;

      if (e.shiftKey) {
        if (active === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        if (active === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }
  });
</script>
