---
// Proof strip — verifiable numbers surfaced from real work history (see data/experience.ts).
const stats = [
  { value: '6+', label: 'Years building production systems' },
  { value: '25–30', label: 'Legacy .NET apps modernized' },
  { value: '80%', label: 'Faster page loads (15s → 3s)' },
  { value: '10+', label: 'Microservices shipped' },
];
---

<section class="proof" aria-label="Key results">
  <div class="container">
    <ul class="proof-grid reveal-stagger">
      {stats.map((s) => (
        <li class="proof-item">
          <span class="proof-value">{s.value}</span>
          <span class="proof-label">{s.label}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .proof {
    padding: 0 0 1rem;
  }

  .proof-grid {
    list-style: none;
    margin: 0;
    padding: 1.75rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .proof-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-align: center;
    position: relative;
  }

  .proof-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 60%;
    background: var(--border);
  }

  .proof-value {
    font-family: var(--font-mono);
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .proof-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .proof-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
      padding: 1.5rem;
    }

    .proof-item:nth-child(2)::after {
      display: none;
    }
  }

  @media (max-width: 400px) {
    .proof-grid {
      grid-template-columns: 1fr 1fr;
    }
    .proof-value {
      font-size: 1.5rem;
    }
  }
</style>
