---
import Icon from './Icon.astro';

interface Props {
  isBlog?: boolean;
}

const { isBlog = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const sectionItems = [
  { label: 'About', anchor: '#about' },
  { label: 'Experience', anchor: '#experience' },
  { label: 'Projects', anchor: '#projects' },
  { label: 'Skills', anchor: '#skills' },
  { label: 'Contact', anchor: '#contact' },
];

const navItems = [
  ...sectionItems.map((item) => ({
    label: item.label,
    href: isBlog ? `${base}/${item.anchor}` : item.anchor,
  })),
  { label: 'Blog', href: `${base}/blog/` },
];

const logoHref = isBlog ? `${base}/` : '#hero';
---

<nav class={`nav${isBlog ? ' scrolled' : ''}`} id="nav">
  <div class="container nav-inner">
    <a href={logoHref} class="nav-logo">AK</a>
    <ul class="nav-links" id="nav-links">
      {navItems.map((item) => (
        <li><a href={item.href} class={`nav-link${item.label === 'Blog' ? ' nav-link--blog' : ''}`}>{item.label}</a></li>
      ))}
    </ul>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle menu">
      <Icon name="menu" size={24} />
    </button>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 0;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .nav.scrolled {
    background: rgba(10, 10, 15, 0.9);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: color 0.2s;
    font-weight: 500;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: width 0.3s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--accent);
  }

  .nav-link.active::after {
    width: 100%;
  }

  /* Blog link — accent pill style */
  .nav-link--blog {
    color: var(--accent);
    border: 1px solid rgba(56, 189, 248, 0.4);
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .nav-link--blog::after {
    display: none;
  }

  .nav-link--blog:hover {
    background: var(--accent-glow);
    border-color: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
  }

  .nav-toggle {
    display: none;
    color: var(--text);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: 0;
      width: 70%;
      max-width: 300px;
      height: 100vh;
      background: var(--bg-card);
      flex-direction: column;
      padding: 5rem 2rem 2rem;
      gap: 1.5rem;
      transform: translateX(100%);
      transition: transform 0.3s ease;
      box-shadow: -4px 0 20px rgba(0, 0, 0, 0.5);
    }

    .nav-links.open {
      transform: translateX(0);
    }

    .nav-link {
      font-size: 1.1rem;
    }
  }
</style>
