---
interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<div class="section-heading reveal-line" id={id}>
  <h2>{title}</h2>
  <div class="heading-line"></div>
</div>

<style>
  .section-heading {
    margin-bottom: 3rem;
    text-align: center;
  }

  h2 {
    font-size: 2.25rem;
    letter-spacing: -0.025em;
    color: var(--text);
  }

  .heading-line {
    width: 64px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), rgba(56, 189, 248, 0.3));
    margin: 0.85rem auto 0;
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-line.visible .heading-line {
    transform: scaleX(1);
  }

  @media (min-width: 768px) {
    h2 {
      font-size: 2.75rem;
    }
  }
</style>
