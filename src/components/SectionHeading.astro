---
interface Props {
  title: string;
  id?: string;
  as?: 'h1' | 'h2';
}

const { title, id, as = 'h2' } = Astro.props;
const Heading = as;
---

<div class="section-heading reveal-line" id={id}>
  <Heading>{title}</Heading>
  <div class="heading-line"></div>
</div>

<style>
  .section-heading {
    margin-bottom: 3rem;
    text-align: center;
  }

  h1,
  h2 {
    font-size: 2.25rem;
    letter-spacing: -0.025em;
    color: var(--text);
  }

  .heading-line {
    width: 64px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), rgba(56, 189, 248, 0.3));
    margin: 0.85rem auto 0;
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-line.visible .heading-line {
    transform: scaleX(1);
  }

  @media (min-width: 768px) {
    h1,
    h2 {
      font-size: 2.75rem;
    }
  }
</style>
