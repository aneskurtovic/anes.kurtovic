---
interface Props {
  title: string;
  id?: string;
}

const { title, id } = Astro.props;
---

<div class="section-heading" id={id}>
  <h2>{title}</h2>
  <div class="heading-line"></div>
</div>

<style>
  .section-heading {
    margin-bottom: 3rem;
    text-align: center;
  }

  h2 {
    font-size: 2rem;
    letter-spacing: -0.02em;
  }

  .heading-line {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), rgba(56, 189, 248, 0.3));
    margin: 0.75rem auto 0;
    border-radius: 2px;
  }

  @media (min-width: 768px) {
    h2 {
      font-size: 2.5rem;
    }
  }
</style>
