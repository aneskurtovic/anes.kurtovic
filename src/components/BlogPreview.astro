---
import { getCollection } from 'astro:content';
import SectionHeading from './SectionHeading.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

{posts.length > 0 && (
  <section id="blog" class="reveal">
    <div class="container">
      <SectionHeading title="Latest Posts" />

      <div class="blog-grid reveal-stagger">
        {posts.map((post) => {
          const formattedDate = post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <a href={`${import.meta.env.BASE_URL}/blog/${post.id}/`} class="blog-card">
              <div class="blog-card-header">
                <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              </div>
              <h3 class="blog-card-title">{post.data.title}</h3>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-card-tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          );
        })}
      </div>

      <div class="view-all">
        <a href={`${import.meta.env.BASE_URL}/blog/`} class="view-all-link">
          View all posts &rarr;
        </a>
      </div>
    </div>
  </section>
)}

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: transform 0.3s, background 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    background: var(--bg-card-hover);
    box-shadow: 0 0 20px var(--accent-glow), 0 8px 25px rgba(0, 0, 0, 0.3);
    border-color: rgba(56, 189, 248, 0.3);
  }

  .blog-card-header {
    margin-bottom: 0.75rem;
  }

  .blog-card-header time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
  }

  .blog-card-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .blog-card-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
    flex: 1;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--accent-glow);
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius);
  }

  .view-all {
    text-align: center;
    margin-top: 2rem;
  }

  .view-all-link {
    color: var(--accent);
    font-weight: 500;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .view-all-link:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
