---
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';
import { projects } from '../data/projects';

const featured = projects.filter((p) => p.featured);
const other = projects.filter((p) => !p.featured);
---

<section id="projects" class="reveal">
  <div class="container">
    <SectionHeading title="Projects" />

    {featured.map((project) => (
      <div class="featured-card reveal">
        <div class="featured-header">
          <h3 class="featured-name">{project.name}</h3>
          <p class="featured-subtitle">{project.subtitle}</p>
        </div>
        <p class="featured-description">{project.description}</p>
        {project.highlights && project.highlights.length > 0 && (
          <ul class="featured-highlights">
            {project.highlights.map((h) => (
              <li>{h}</li>
            ))}
          </ul>
        )}
        <div class="featured-tags">
          {project.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <div class="featured-links">
          {project.live && (
            <a href={project.live} target="_blank" rel="noopener noreferrer" class="live-link">
              <Icon name="external-link" size={16} />
              <span>Live Demo</span>
            </a>
          )}
          {project.github && (
            <a href={project.github} target="_blank" rel="noopener noreferrer" class="github-link">
              <Icon name="github" size={16} />
              <span>Source Code</span>
            </a>
          )}
        </div>
      </div>
    ))}

    <div class="projects-grid reveal-stagger">
      {other.map((project) => (
        <div class="project-card">
          <div class="project-header">
            <h3 class="project-name">{project.name}</h3>
            <p class="project-subtitle">{project.subtitle}</p>
          </div>
          <p class="project-description">{project.description}</p>
          {project.highlights && project.highlights.length > 0 && (
            <ul class="project-highlights">
              {project.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          )}
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          {project.github && (
            <div class="project-links">
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="github-link">
                <Icon name="github" size={16} />
                <span>Source Code</span>
              </a>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Featured card */
  .featured-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-top: 2px solid var(--accent);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-bottom: 2rem;
    transition: box-shadow 0.3s;
  }

  .featured-card:hover {
    box-shadow: 0 0 30px var(--accent-glow), 0 8px 30px rgba(0, 0, 0, 0.2);
  }

  .featured-header {
    margin-bottom: 1rem;
  }

  .featured-name {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .featured-subtitle {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .featured-description {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .featured-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .featured-highlights li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .featured-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .featured-links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .live-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.95rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    transition: background 0.2s, box-shadow 0.2s;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  .live-link:hover {
    background: var(--accent-glow);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 5px transparent;
    }
    50% {
      box-shadow: 0 0 12px var(--accent-glow);
    }
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .github-link:hover {
    color: var(--accent);
  }

  /* Non-featured grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: transform 0.3s, background 0.3s, box-shadow 0.3s, border-color 0.3s;
  }

  .project-card:hover {
    transform: translateY(-4px);
    background: var(--bg-card-hover);
    box-shadow: 0 0 20px var(--accent-glow), 0 8px 25px rgba(0, 0, 0, 0.3);
    border-color: rgba(56, 189, 248, 0.3);
  }

  .project-header {
    margin-bottom: 0.75rem;
  }

  .project-name {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .project-subtitle {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .project-description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .project-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .project-highlights li {
    position: relative;
    padding-left: 1.1rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  .project-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .project-links {
    margin-top: auto;
  }

  /* Shared tag style */
  .tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--accent-glow);
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }

    .featured-card {
      padding: 1.5rem;
    }
  }
</style>
