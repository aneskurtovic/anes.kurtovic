---
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';
import { projects } from '../data/projects';
---

<section id="projects" class="reveal">
  <div class="container">
    <SectionHeading title="Projects" />
    <div class="proj-list reveal-stagger">
      {projects.map((project, i) => (
        <details class="proj-row" open={i === 0}>
          <summary class="proj-summary">
            <span class="proj-type-icon" aria-hidden="true">{project.live ? '◆' : '◇'}</span>
            <span class="proj-name">{project.name}</span>
            <span class="proj-divider">/</span>
            <span class="proj-subtitle">{project.subtitle}</span>
            <span class="proj-status">{project.live ? 'Live' : 'Source'}</span>
            <span class="proj-chevron" aria-hidden="true">+</span>
          </summary>
          <div class="proj-body">
            {project.highlights && project.highlights[0] && (
              <p class="proj-headline">{project.highlights[0]}</p>
            )}
            {project.highlights && project.highlights.length > 1 && (
              <ul class="proj-bullets">
                {project.highlights.slice(1).map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
            )}
            <div class="proj-tags">
              {project.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <div class="proj-links">
              {project.live && (
                <a href={project.live} target="_blank" rel="noopener noreferrer" class="live-link">
                  <Icon name="external-link" size={14} />
                  <span>Live Demo</span>
                </a>
              )}
              {project.github && (
                <a href={project.github} target="_blank" rel="noopener noreferrer" class="github-link">
                  <Icon name="github" size={14} />
                  <span>Source Code</span>
                </a>
              )}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .proj-list {
    max-width: 920px;
    margin: 0 auto;
  }

  .proj-row {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }

  .proj-row:last-child {
    border-bottom: none;
  }

  .proj-summary {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: 28px auto auto 1fr auto 1.25rem;
    align-items: center;
    gap: 0.65rem;
  }

  .proj-summary::-webkit-details-marker { display: none; }

  .proj-type-icon {
    color: var(--accent);
    font-size: 0.9rem;
    text-align: center;
  }

  .proj-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
  }

  .proj-divider {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .proj-subtitle {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .proj-status {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .proj-chevron {
    color: var(--accent);
    font-size: 1.1rem;
    font-family: var(--font-mono);
    transition: transform 0.25s;
    justify-self: end;
  }

  .proj-row[open] .proj-chevron {
    transform: rotate(45deg);
  }

  .proj-body {
    padding: 1rem 0 0.5rem 28px;
    margin-top: 0.25rem;
  }

  .proj-headline {
    font-size: 1rem;
    color: var(--text);
    line-height: 1.55;
    margin-bottom: 0.85rem;
  }

  .proj-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .proj-bullets li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  .proj-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--accent-glow);
    color: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius);
  }

  .proj-links {
    display: flex;
    gap: 0.85rem;
    align-items: center;
  }

  .live-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.85rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    transition: background 0.2s, box-shadow 0.2s;
  }

  .live-link:hover {
    background: var(--accent-glow);
    box-shadow: 0 0 18px var(--accent-glow);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    transition: color 0.2s;
  }

  .github-link:hover {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .proj-summary {
      grid-template-columns: 24px 1fr auto 1.25rem;
      grid-template-rows: auto auto;
      column-gap: 0.5rem;
      row-gap: 0.25rem;
    }
    .proj-type-icon { grid-row: 1; grid-column: 1; }
    .proj-name { grid-row: 1; grid-column: 2; }
    .proj-status { grid-row: 1; grid-column: 3; }
    .proj-chevron { grid-row: 1; grid-column: 4; }
    .proj-divider { display: none; }
    .proj-subtitle {
      grid-row: 2;
      grid-column: 2 / -1;
      white-space: normal;
    }
    .proj-body { padding-left: 0; }
  }
</style>
