---
import SectionHeading from './SectionHeading.astro';
import { experiences } from '../data/experience';

function startYear(period: string): string {
  const match = period.match(/(\d{4})/);
  return match ? match[1] : '';
}
---

<section id="experience" class="reveal">
  <div class="container">
    <SectionHeading title="Experience" />
    <div class="exp-timeline reveal-stagger">
      {experiences.map((exp, i) => (
        <details class="exp-row" open={i === 0}>
          <summary class="exp-summary">
            <span class="exp-year">{startYear(exp.period)}</span>
            <span class="exp-dot" aria-hidden="true"></span>
            <span class="exp-company">{exp.company}</span>
            <span class="exp-divider">/</span>
            <span class="exp-project">{exp.project}</span>
            <span class="exp-chevron" aria-hidden="true">+</span>
          </summary>
          <div class="exp-body">
            <p class="exp-headline">{exp.shortBullets[0]}</p>
            <p class="exp-meta">{exp.role} <span class="dot">·</span> {exp.period} <span class="dot">·</span> {exp.location}</p>
            <ul class="exp-bullets">
              {exp.shortBullets.slice(1).map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
            <div class="exp-tags">
              {exp.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .exp-timeline {
    position: relative;
    padding-left: 2rem;
    max-width: 920px;
    margin: 0 auto;
  }

  .exp-timeline::before {
    content: '';
    position: absolute;
    left: 0.75rem;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent) 0%, var(--border) 100%);
  }

  .exp-row {
    position: relative;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
  }

  .exp-row:last-child {
    border-bottom: none;
  }

  .exp-summary {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: 60px auto auto auto 1fr;
    align-items: center;
    gap: 0.65rem;
  }

  .exp-summary::-webkit-details-marker { display: none; }

  .exp-year {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
  }

  .exp-dot {
    position: absolute;
    left: -1.625rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg);
    border: 3px solid var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
  }

  .exp-company {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .exp-divider {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .exp-project {
    font-size: 0.95rem;
    color: var(--accent);
    font-family: var(--font-mono);
  }

  .exp-chevron {
    color: var(--accent);
    font-size: 1.1rem;
    font-family: var(--font-mono);
    transition: transform 0.25s;
    justify-self: end;
  }

  .exp-row[open] .exp-chevron {
    transform: rotate(45deg);
  }

  .exp-headline {
    font-size: 1rem;
    color: var(--text);
    line-height: 1.55;
    margin-bottom: 0.85rem;
  }

  .exp-body {
    padding: 1rem 0 0.5rem 60px;
    margin-top: 0.5rem;
  }

  .exp-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    margin-bottom: 0.85rem;
  }

  .dot { opacity: 0.5; margin: 0 0.2rem; }

  .exp-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .exp-bullets li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  .exp-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }

  .exp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--accent-glow);
    color: var(--accent);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius);
  }

  @media (max-width: 768px) {
    .exp-summary {
      grid-template-columns: 50px 1fr auto;
      column-gap: 0.5rem;
    }
    .exp-divider, .exp-project { display: none; }
    .exp-body {
      padding-left: 0;
    }
  }
</style>
