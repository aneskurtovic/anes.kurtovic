---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { experiences } from '../data/experience';
import { skills } from '../data/skills';
import { certifications } from '../data/certifications';
import { contactInfo, socialLinks } from '../data/social';

const githubUrl = socialLinks.find((s) => s.name === 'GitHub')?.url ?? '';
const linkedinUrl = socialLinks.find((s) => s.name === 'LinkedIn')?.url ?? '';
---

<Layout
  title="Résumé | Anes Kurtovic"
  description="Résumé of Anes Kurtovic — Backend & Platform Engineer (.NET, cloud-native, real-time systems)."
>
  <Nav isBlog />
  <main id="main" class="resume-page">
    <div class="resume">
      <header class="resume-head">
        <div>
          <h1>Anes Kurtovic</h1>
          <p class="resume-role">Backend &amp; Platform Engineer · .NET, Cloud-Native, Real-Time Systems</p>
          <p class="resume-contact">
            <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
            <span class="sep">·</span>
            <span>{contactInfo.location}</span>
            <span class="sep">·</span>
            <a href={githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
            <span class="sep">·</span>
            <a href={linkedinUrl} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </p>
        </div>
        <a href="/Anes_Kurtovic_2025.pdf" target="_blank" rel="noopener noreferrer" class="pdf-btn">
          Download PDF <span aria-hidden="true">↓</span>
        </a>
      </header>

      <section class="resume-section">
        <h2>Summary</h2>
        <p class="resume-summary">
          Software engineer with 6+ years in backend and platform engineering — .NET, SQL,
          cloud-native services, and real-time systems. I modernize legacy .NET estates into
          maintainable platforms, design event-sourced microservices, and ship features teams
          can operate in production.
        </p>
      </section>

      <section class="resume-section">
        <h2>Experience</h2>
        {experiences.map((job) => (
          <div class="resume-job">
            <div class="resume-job-head">
              <span class="resume-job-title">{job.role} — {job.company}</span>
              <span class="resume-job-period">{job.period}</span>
            </div>
            <p class="resume-job-meta">{job.project} · {job.location}</p>
            <ul>
              {job.shortBullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        ))}
      </section>

      <section class="resume-section">
        <h2>Skills</h2>
        <dl class="resume-skills">
          {skills.map((cat) => (
            <div class="resume-skill-row">
              <dt>{cat.name}</dt>
              <dd>{cat.items.join(' · ')}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="resume-section">
        <h2>Certifications</h2>
        <ul class="resume-certs">
          {certifications.map((c) => (
            <li>{c.name} <span class="cert-meta">({c.code} · {c.year})</span></li>
          ))}
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .resume-page {
    padding-top: 6rem;
    padding-bottom: 4rem;
    min-height: 100vh;
  }

  .resume {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .resume-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .resume-head h1 {
    font-size: 2.25rem;
    margin-bottom: 0.35rem;
  }

  .resume-role {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-bottom: 0.6rem;
  }

  .resume-contact {
    font-size: 0.9rem;
    color: var(--text-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }

  .resume-contact a:hover { color: var(--accent); }
  .resume-contact .sep { opacity: 0.4; }

  .pdf-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1.1rem;
    background: var(--accent);
    color: var(--bg);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--radius);
    white-space: nowrap;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .pdf-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .resume-section {
    padding: 0;
    margin-bottom: 2.25rem;
  }

  .resume-section h2 {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .resume-summary {
    line-height: 1.7;
  }

  .resume-job {
    margin-bottom: 1.5rem;
  }

  .resume-job-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .resume-job-title {
    font-weight: 600;
    color: var(--text);
  }

  .resume-job-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .resume-job-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0.15rem 0 0.6rem;
  }

  .resume-job ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .resume-job li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--text-muted);
  }

  .resume-job li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .resume-skills {
    margin: 0;
  }

  .resume-skill-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
  }

  .resume-skill-row:last-child { border-bottom: none; }

  .resume-skill-row dt {
    font-weight: 600;
    color: var(--text);
    font-size: 0.9rem;
  }

  .resume-skill-row dd {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .resume-certs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .resume-certs li {
    color: var(--text);
    font-size: 0.92rem;
  }

  .cert-meta {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  @media (max-width: 600px) {
    .resume-skill-row {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
    .resume-head h1 { font-size: 1.8rem; }
  }

  @media print {
    .pdf-btn { display: none; }
    .resume-page { padding-top: 1rem; }
  }
</style>
