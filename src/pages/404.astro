---
// Branded 404. Astro emits this as 404.html, which GitHub Pages serves (with a
// real 404 status) for any unknown path — so visitors land on-brand with a way
// back instead of GitHub's generic error page.
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 — Page Not Found | Anes Kurtovic"
  description="The page you're looking for doesn't exist or has moved."
>
  <Nav isBlog />
  <main id="main" class="notfound">
    <div class="nf-inner">
      <p class="nf-code">404</p>
      <h1 class="nf-title">Page not found</h1>
      <p class="nf-text">
        The page you're looking for doesn't exist or has moved. Let's get you back
        on track.
      </p>
      <div class="nf-actions">
        <a href="/" class="nf-btn nf-btn--primary">&larr; Back home</a>
        <a href="/blog/" class="nf-btn">Read the blog</a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .notfound {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 6rem 1.5rem 4rem;
  }

  .nf-inner {
    text-align: center;
    max-width: 34rem;
  }

  .nf-code {
    font-family: var(--font-mono);
    font-size: clamp(4rem, 18vw, 8rem);
    font-weight: 700;
    line-height: 1;
    margin: 0 0 0.5rem;
    background: linear-gradient(90deg, var(--accent), rgba(56, 189, 248, 0.35));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .nf-title {
    font-size: 1.75rem;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .nf-text {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .nf-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .nf-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.6rem 1.2rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 600;
    transition: border-color 0.2s, color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .nf-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .nf-btn--primary {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  .nf-btn--primary:hover {
    color: var(--bg);
    box-shadow: 0 0 20px var(--accent-glow);
  }
</style>
